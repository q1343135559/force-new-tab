{
    "manifest_version": 3,
    "name": "强制新标签页打开 (终极版)",
    "version": "3.0",
    "description": "彻底解决 SPA 异步假链接跳转及拦截问题。",
    "permissions": [
        "tabs"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_start"
        },
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "inject.js"
            ],
            "run_at": "document_start",
            "world": "MAIN"
        }
    ]
}